# Variables de entorno – TECNOMEDIC
# NUNCA subir a GitHub · Cargar en Render → Environment

# Flask
SECRET_KEY=CAMBIAR_POR_CLAVE_SEGURA

# Panel Admin
ADMIN_USER=admin
